  "version": "0.2.0",
  "configurations": [
    {
      "name": "main | single-agent",
      "type": "debugpy",
      "request": "launch",
      "program": "main.py",
      "console": "integratedTerminal",
      "justMyCode": false,
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "args": [
        "--executable_file=../virtualhome/unity/macos_exec.2.2.4.app",
        // "--dataset_path=./dataset/2_per_apt-task_no_tv-apts_0,1,2,4,5-subset_20.pik",
        "--dataset_path=./dataset/gnp_single_item/all_tasks.pik",
        "--num_agents=1",
        "--base_port=8088",
        "--num_runs=1",
        "--obs_type=partial"
        // "--debug",
        // "--episode_ids=0"
      ],
      "preLaunchTask": "clear :8088"
    },
    {
      "name": "main | human-ai",
      "type": "debugpy",
      "request": "launch",
      "program": "main.py",
      "console": "integratedTerminal",
      "justMyCode": false,
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "args": [
        "--executable_file=../virtualhome/unity/macos_exec.2.2.4.app",
        "--dataset_path=./dataset/2_per_apt-task_no_tv-apts_0,1,2,4,5-subset_20.pik",
        // "--dataset_path=./dataset/2_per_apt-task_all-apts_3,6.pik",
        "--num_agents=2",
        // "--num_agents=1",
        "--autotom_method=llm",
        // "--autotom_method=autotom",
        // "--autotom_proposer_name=gemini/gemini-2.5-flash-lite-preview-06-17",
        // "--autotom_proposer_name=gemini/gemini-2.5-flash",
        // "--autotom_proposer_name=gemini/gemini-2.0-flash-thinking-exp-01-21",
        // "--autotom_proposer_name=o3-mini",
        "--autotom_proposer_name=hosted_vllm/qwen3-235b-fp8",
        "--autotom_estimator_name=hosted_vllm/qwen3-235b-fp8",
        "--helper_class=GnP",
        // "--gnp_thres_grab=0.7",
        "--gnp_thres_grab=2.0", // * don't act at all
        "--autotom_num_particles=10",
        // "--helper_goal_type=gt",
        "--base_port=8088",
        "--num_runs=1",
        "--debug",
        // "--episode_ids=0",
        // "--max_steps=50",
        // "--autotom_start_at_put",
        // "--autotom_num_particles=3",
      ],
      "preLaunchTask": "clear :8088"
    },
    {
      "name": "AutoToM_prompts",
      "type": "debugpy",
      "request": "launch",
      "program": "agents/AutoToM_prompts.py",
      "console": "integratedTerminal",
      "justMyCode": false,
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    },
    {
      "name": "utils.utils_graph",
      "type": "debugpy",
      "request": "launch",
      "program": "utils/utils_graph.py",
      "console": "integratedTerminal",
      "justMyCode": false,
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    },
    {
      "name": "vh_init_structured",
      "type": "debugpy",
      "request": "launch",
      "program": "gen_data/vh_init_structured.py",
      "console": "integratedTerminal",
      "justMyCode": false,
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "args": ["--exec_file=../virtualhome/unity/macos_exec.2.2.4.app"]
    },
    {
      "name": "vh_gnp_single_item",
      "type": "debugpy",
      "request": "launch",
      "program": "gen_data/vh_gnp_single_item.py",
      "console": "integratedTerminal",
      "justMyCode": false,
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "args": ["--num_per_apt=3"]
    }
  ]
}
