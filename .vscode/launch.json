  "version": "0.2.0",
  "configurations": [
    {
      "name": "main",
      "type": "debugpy",
      "request": "launch",
      "program": "main.py",
      "console": "integratedTerminal",
      "justMyCode": false,
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "args": [
        "--executable_file=../../ShunchiZhang/virtualhome/unity/macos_exec.2.2.4.app",
        // "--dataset_path=./dataset/2_per_apt-task_all-apts_0,1,2,4,5.pik",
        "--dataset_path=./dataset/2_per_apt-task_setup_table-apts_0,1,2,4,5.pik",
        "--num_agents=2",
        // "--autotom_method=llm",
        // "--helper_class=MCTS",
        // "--helper_goal_type=gt",
        "--autotom_method=autotom",
        "--base_port=8999",
        "--debug",
        "--num_runs=1",
        // "--max_steps=50",
        "--episode_ids=0",
        // "--autotom_llm_name=gpt-4o-mini",
        // "--autotom_start_at_put",
        // "--autotom_num_particles=3",
      ],
      "preLaunchTask": "clear :8088"
    },
    {
      "name": "vh_init_structured",
      "type": "debugpy",
      "request": "launch",
      "program": "gen_data/vh_init_structured.py",
      "console": "integratedTerminal",
      "justMyCode": false,
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "args": [
        "--exec_file=../../ShunchiZhang/virtualhome/unity/macos_exec.2.2.4.app",
      ]
    }
  ]
}
