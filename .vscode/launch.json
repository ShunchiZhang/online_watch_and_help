  "version": "0.2.0",
  "configurations": [
    {
      "name": "main",
      "type": "debugpy",
      "request": "launch",
      "program": "main.py",
      "console": "integratedTerminal",
      "justMyCode": false,
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "args": [
        "--executable_file=../../ShunchiZhang/virtualhome/unity/macos_exec.2.2.4.app",
        "--dataset_path=./dataset/structured_agent/train_env_task_set_2_full_task.all_apts.0,1,2,4,5.pik",
        "--debug",
        "--num_agents=2",
        "--base_port=8088",
        "--image_width=160",
        "--image_height=120",
        // "--autotom_method=llm",
        "--autotom_method=autotom",
        // "--autotom_start_at_put",
        "--autotom_num_particles=5",
        "--autotom_thres_filter=0.2"
      ],
      "preLaunchTask": "clear :8088"
    },
    {
      "name": "vh_init_structured",
      "type": "debugpy",
      "request": "launch",
      "program": "gen_data/vh_init_structured.py",
      "console": "integratedTerminal",
      "justMyCode": false,
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "args": [
        "--exec_file=../../ShunchiZhang/virtualhome/unity/macos_exec.2.2.4.app",
      ]
    }
  ]
}
